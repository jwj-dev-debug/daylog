<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F8F8">

    <!-- 🔙 상단바 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@android:color/white"
        android:elevation="4dp"
        android:orientation="horizontal">

        <!-- 뒤로가기 버튼 -->
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textSize="24sp"
            android:textStyle="bold"
            android:padding="8dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- 제목 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PIN 변경"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <!-- 내용 영역 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 카드 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/white"
                android:padding="20dp"
                android:elevation="4dp"
                android:orientation="vertical"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="20dp">

                <!-- 기존 PIN -->
                <EditText
                    android:id="@+id/etOldPin"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="현재 PIN 입력"
                    android:padding="12dp"
                    android:background="@android:drawable/edit_text"
                    android:inputType="numberPassword"
                    android:textSize="16sp"
                    android:layout_marginBottom="14dp" />

                <!-- 새 PIN -->
                <EditText
                    android:id="@+id/etNewPin"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="새 PIN 입력 (4자리 이상)"
                    android:padding="12dp"
                    android:background="@android:drawable/edit_text"
                    android:inputType="numberPassword"
                    android:textSize="16sp"
                    android:layout_marginBottom="14dp" />

                <!-- 새 PIN 확인 -->
                <EditText
                    android:id="@+id/etNewPinConfirm"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="새 PIN 다시 입력"
                    android:padding="12dp"
                    android:background="@android:drawable/edit_text"
                    android:inputType="numberPassword"
                    android:textSize="16sp"
                    android:layout_marginBottom="20dp" />

                <!-- 변경 버튼 -->
                <Button
                    android:id="@+id/btnApplyPinChange"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="변경하기"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:backgroundTint="#6C5CE7"
                    android:background="@drawable/rounded_button" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
