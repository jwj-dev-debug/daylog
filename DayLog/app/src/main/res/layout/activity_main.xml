<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 상단 앱바 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingHorizontal="4dp"
            android:paddingVertical="8dp">

            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@mipmap/ic_launcher" />

            <TextView
                android:id="@+id/tvAppTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="DayLog"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- 내용 카드 영역 -->
        <LinearLayout
            android:id="@+id/layoutCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@android:color/white"
            android:orientation="vertical"
            android:padding="24dp"
            android:elevation="2dp">

            <!-- 제목 -->
            <TextView
                android:id="@+id/tvStartTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="DayLog 시작하기"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginBottom="24dp" />

            <!-- 사용자 이름 -->
            <TextView
                android:id="@+id/tvUserNameLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="사용자 이름"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etUserName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@android:drawable/edit_text"
                android:padding="10dp"
                android:hint="이름을 입력하세요" />

            <!-- 이메일 -->
            <TextView
                android:id="@+id/tvEmailLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="이메일"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:background="@android:drawable/edit_text"
                android:padding="10dp"
                android:inputType="textEmailAddress"
                android:hint="이메일을 입력하세요" />

            <!-- ✅ 비밀번호 -->
            <TextView
                android:id="@+id/tvPasswordLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="비밀번호"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="20dp"
                android:background="@android:drawable/edit_text"
                android:padding="10dp"
                android:inputType="textPassword"
                android:hint="비밀번호를 입력하세요 (6자 이상)" />

            <!-- 관심 활동 카테고리 제목 -->
            <TextView
                android:id="@+id/tvCategoryLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="활동 카테고리 선택 (복수 선택 가능)"
                android:textSize="14sp"
                android:layout_marginBottom="12dp" />

            <!-- 카테고리 버튼 그리드 -->
            <GridLayout
                android:id="@+id/gridCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="3"
                android:useDefaultMargins="true">

                <!-- 운동 -->
                <Button
                    android:id="@+id/btnCategoryExercise"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:text="🏃‍♂️\n운동"
                    android:textAllCaps="false"
                    android:textColor="@android:color/black"
                    android:textSize="16sp"
                    android:backgroundTint="#E5E7EB" />

                <!-- 독서 -->
                <Button
                    android:id="@+id/btnCategoryReading"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:text="📚\n독서"
                    android:textAllCaps="false"
                    android:textColor="@android:color/black"
                    android:textSize="16sp"
                    android:backgroundTint="#E5E7EB" />

                <!-- 공부 -->
                <Button
                    android:id="@+id/btnCategoryStudy"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:text="🎓\n공부"
                    android:textAllCaps="false"
                    android:textColor="@android:color/black"
                    android:textSize="16sp"
                    android:backgroundTint="#E5E7EB" />

                <!-- 요리 -->
                <Button
                    android:id="@+id/btnCategoryCooking"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:text="🍳\n요리"
                    android:textAllCaps="false"
                    android:textColor="@android:color/black"
                    android:textSize="16sp"
                    android:backgroundTint="#E5E7EB" />

                <!-- 취미 -->
                <Button
                    android:id="@+id/btnCategoryHobby"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:text="🎨\n취미"
                    android:textAllCaps="false"
                    android:textColor="@android:color/black"
                    android:textSize="16sp"
                    android:backgroundTint="#E5E7EB" />

                <!-- 업무 -->
                <Button
                    android:id="@+id/btnCategoryWork"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_columnWeight="1"
                    android:gravity="center"
                    android:text="💼\n업무"
                    android:textAllCaps="false"
                    android:textColor="@android:color/black"
                    android:textSize="16sp"
                    android:backgroundTint="#E5E7EB" />
            </GridLayout>

            <!-- 시작하기 버튼 -->
            <Button
                android:id="@+id/btnStart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:paddingVertical="12dp"
                android:text="시작하기"
                android:textAllCaps="false"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                android:backgroundTint="#2563EB" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
