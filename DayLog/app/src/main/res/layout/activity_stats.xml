<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 상단 앱바 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:paddingVertical="8dp">

            <TextView
                android:id="@+id/tvBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="〈"
                android:textSize="20sp"
                android:padding="4dp" />

            <TextView
                android:id="@+id/tvPrevMonth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◀"
                android:textSize="18sp"
                android:padding="12dp" />

            <TextView
                android:id="@+id/tvStatsMonthTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2025년 11월 통계"
                android:textSize="20sp"
                android:gravity="center"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvNextMonth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="▶"
                android:textSize="18sp"
                android:padding="12dp" />

        </LinearLayout>



        <!-- 🎀 카드 1 : 이번 달 기록한 날 (파스텔 블루) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:elevation="2dp"
            android:background="@drawable/card1_pastel">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="이번 달 기록한 날"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvTotalRecordDays"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="-일"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:gravity="center"
                android:layout_marginTop="6dp" />

        </LinearLayout>



        <!-- 🎀 카드 2 : 총 기록 개수 (파스텔 핑크) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:elevation="2dp"
            android:background="@drawable/card2_pastel">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="이번 달 총 기록 개수"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvTotalRecords"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="-개"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:gravity="center"
                android:layout_marginTop="6dp" />

        </LinearLayout>



        <!-- 🎀 카드 3 : 가장 많이 한 활동 (파스텔 민트) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:elevation="2dp"
            android:background="@drawable/card3_pastel">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="이번 달 가장 많이 한 활동"
                android:textStyle="bold"
                android:textColor="#333333"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvTopCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="-"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#333333"
                android:gravity="center"
                android:layout_marginTop="6dp" />

        </LinearLayout>



        <!-- 📊 카드 4 : 막대 그래프 카드(화이트) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="330dp"
            android:padding="16dp"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:background="@drawable/card_white_round"
            android:elevation="3dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="카테고리별 기록 횟수"
                android:gravity="center"
                android:textSize="15sp"
                android:textStyle="bold"
                android:layout_marginBottom="10dp" />

            <LinearLayout
                android:id="@+id/layoutBarChart"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:id="@+id/layoutBarLabels"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="8dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
