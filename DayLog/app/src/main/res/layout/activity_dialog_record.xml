<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#80000000">

    <!-- 가운데 하얀 팝업 카드 -->
    <LinearLayout
        android:id="@+id/layoutPopupCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_margin="16dp"
        android:orientation="vertical"
        android:background="@android:color/white"
        android:padding="20dp"
        android:elevation="4dp">

        <!-- 상단: 날짜 + 닫기 버튼 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvSelectedDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="2025년 11월 11일"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvClose"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕"
                android:textSize="18sp"
                android:padding="4dp" />
        </LinearLayout>

        <!-- 내용 스크롤 영역 -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp"
            android:fillViewport="true"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/layoutActivityList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- 운동 -->
                <LinearLayout
                    android:id="@+id/cardExercise"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    android:background="#F5F7FA">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🏃‍♂️"
                            android:textSize="18sp"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:id="@+id/tvExerciseTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="운동"
                            android:textStyle="bold"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/etExerciseMemo"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginTop="10dp"
                        android:background="@android:color/white"
                        android:gravity="top|start"
                        android:padding="10dp"
                        android:hint="운동 활동을 기록해주세요..."
                        android:inputType="textMultiLine"
                        android:maxLines="5" />
                </LinearLayout>

                <!-- 독서 -->
                <LinearLayout
                    android:id="@+id/cardReading"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    android:background="#F5F7FA">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📘"
                            android:textSize="18sp"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:id="@+id/tvReadingTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="독서"
                            android:textStyle="bold"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/etReadingMemo"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginTop="10dp"
                        android:background="@android:color/white"
                        android:gravity="top|start"
                        android:padding="10dp"
                        android:hint="독서 활동을 기록해주세요..."
                        android:inputType="textMultiLine"
                        android:maxLines="5" />
                </LinearLayout>

                <!-- 공부 -->
                <LinearLayout
                    android:id="@+id/cardStudy"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    android:background="#F5F7FA">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📚"
                            android:textSize="18sp"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:id="@+id/tvStudyTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="공부"
                            android:textStyle="bold"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/etStudyMemo"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginTop="10dp"
                        android:background="@android:color/white"
                        android:gravity="top|start"
                        android:padding="10dp"
                        android:hint="공부 내용을 기록해주세요..."
                        android:inputType="textMultiLine"
                        android:maxLines="5" />
                </LinearLayout>

                <!-- 요리 -->
                <LinearLayout
                    android:id="@+id/cardCooking"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    android:background="#F5F7FA">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🍳"
                            android:textSize="18sp"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:id="@+id/tvCookingTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="요리"
                            android:textStyle="bold"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/etCookingMemo"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginTop="10dp"
                        android:background="@android:color/white"
                        android:gravity="top|start"
                        android:padding="10dp"
                        android:hint="요리한 것들을 기록해주세요..."
                        android:inputType="textMultiLine"
                        android:maxLines="5" />
                </LinearLayout>

                <!-- 취미 -->
                <LinearLayout
                    android:id="@+id/cardHobby"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    android:background="#F5F7FA">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🎨"
                            android:textSize="18sp"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:id="@+id/tvHobbyTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="취미"
                            android:textStyle="bold"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/etHobbyMemo"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginTop="10dp"
                        android:background="@android:color/white"
                        android:gravity="top|start"
                        android:padding="10dp"
                        android:hint="취미 활동을 기록해주세요..."
                        android:inputType="textMultiLine"
                        android:maxLines="5" />
                </LinearLayout>

                <!-- 업무 -->
                <LinearLayout
                    android:id="@+id/cardWork"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:layout_marginBottom="12dp"
                    android:background="#F5F7FA">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💼"
                            android:textSize="18sp"
                            android:layout_marginEnd="6dp" />

                        <TextView
                            android:id="@+id/tvWorkTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="업무"
                            android:textStyle="bold"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/etWorkMemo"
                        android:layout_width="match_parent"
                        android:layout_height="100dp"
                        android:layout_marginTop="10dp"
                        android:background="@android:color/white"
                        android:gravity="top|start"
                        android:padding="10dp"
                        android:hint="업무 내용을 기록해주세요..."
                        android:inputType="textMultiLine"
                        android:maxLines="5" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- 하단 저장 버튼 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="end">

            <Button
                android:id="@+id/btnSave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="저장"
                android:textColor="@android:color/white"
                android:textAllCaps="false"
                android:paddingLeft="24dp"
                android:paddingRight="24dp"
                android:backgroundTint="#3B82F6" />
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
